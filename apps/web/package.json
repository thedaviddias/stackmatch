{
  "name": "@stackmatch/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n next,convex -c blue,magenta \"node scripts/dev-next.mjs\" \"pnpm run dev:convex\"",
    "dev:next": "node scripts/dev-next.mjs",
    "dev:convex": "node scripts/dev-convex.mjs",
    "build": "pnpm typecheck && next build --webpack",
    "start": "next start",
    "lint": "biome check .",
    "check": "pnpm lint && pnpm typecheck",
    "check:sentry": "node scripts/check-sentry-readiness.mjs",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:a11y": "vitest run --config vitest.config.jsdom.ts",
    "test:watch": "vitest",
    "test:watch:a11y": "vitest --config vitest.config.jsdom.ts",
    "test:all": "vitest run && vitest run --config vitest.config.jsdom.ts"
  },
  "dependencies": {

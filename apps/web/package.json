    "@next/mdx": "^16.2.6",
    "@openpanel/nextjs": "^1.5.1",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.55.0",
    "@stackmatch/api": "workspace:*",
    "@stackmatch/config": "workspace:*",
    "@stackmatch/constants": "workspace:*",
    "@stackmatch/email": "workspace:*",
    "@stackmatch/env": "workspace:*",
    "@stackmatch/hooks": "workspace:*",
    "@stackmatch/intents": "workspace:*",
    "@stackmatch/localization": "workspace:*",
    "@stackmatch/logger": "workspace:*",
    "@stackmatch/rate-limit": "workspace:*",
    "@stackmatch/security": "workspace:*",
    "@stackmatch/sentry": "workspace:*",
    "@stackmatch/seo": "workspace:*",
    "@stackmatch/tracking": "workspace:*",
    "@stackmatch/types": "workspace:*",
    "@stackmatch/ui": "workspace:*",
    "@stackmatch/utils": "workspace:*",
    "@stackmatch/vercel": "workspace:*",
    "@tanstack/query-sync-storage-persister": "^5.100.14",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-persist-client": "^5.100.14",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.26",
    "better-auth": "^1.6.12",
    "botid": "^1.5.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "1.39.1",
    "fuse.js": "^7.4.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "nuqs": "2.8.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "sugar-high": "^1.2.0",

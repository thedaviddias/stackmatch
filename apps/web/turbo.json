      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "ANALYZE_API_KEY",
        "BETTER_AUTH_SECRET",
        "CONVEX_DEPLOY_KEY",
        "CONVEX_SITE_URL",
        "FLAGS_SECRET",
        "GITHUB_TOKEN",
        "KV_REST_API_READ_ONLY_TOKEN",

  "dependencies": {
    "@stackmatch/config": "workspace:*",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "@react-email/preview-server": "5.2.10",
    "@types/react": "19.2.16",
    "@types/react-dom": "^19.2.3",
    "react-dom": "19.2.7",
    "react-email": "^6.5.0",
    "vite": "8.0.16",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  }

{
  "name": "@stackmatch/email",
  "description": "Transactional email infrastructure with Resend and React Email templates",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./client": "./src/client.ts",
    "./keys": "./src/keys.ts",
    "./types": "./src/types.ts",
    "./templates/shared/base-layout": "./src/templates/shared/base-layout.tsx",
    "./templates/auth/welcome": "./src/templates/auth/welcome.tsx",
    "./templates/auth/verification": "./src/templates/auth/verification.tsx",
    "./templates/transactional/early-access-invite": "./src/templates/transactional/early-access-invite.tsx",
    "./templates/transactional/notification": "./src/templates/transactional/notification.tsx",
    "./templates/transactional/notification-digest": "./src/templates/transactional/notification-digest.tsx",
    "./templates/transactional/star": "./src/templates/transactional/star.tsx",
    "./templates/transactional/waitlist-confirmation": "./src/templates/transactional/waitlist-confirmation.tsx"
  },
  "scripts": {
    "dev": "email dev --dir src/templates --port 3067",

{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "CI",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "NEXT_PUBLIC_VERCEL_ENV",
    "SKIP_ENV_VALIDATION"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "lint": {},
    "lint:fix": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "test:a11y": {
      "dependsOn": ["^build"],
      "inputs": ["**/*.tsx", "**/*.test.tsx", "test-setup-jsdom.ts", "vitest.config.jsdom.ts"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
